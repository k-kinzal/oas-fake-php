{
    "name": "k-kinzal/oas-fake-php",
    "description": "Intercept HTTP requests, validate against OpenAPI schemas, and generate fake responses for testing",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "openapi",
        "swagger",
        "mock",
        "fake",
        "testing",
        "http",
        "cassette",
        "guzzle",
        "curl"
    ],
    "authors": [
        {
            "name": "k-kinzal",
            "email": "keen.flag7803@logn.in"
        }
    ],
    "require": {
        "php": ">=8.0 <8.6",
        "ext-curl": "*",
        "canvural/php-openapi-faker": "^2.1",
        "devizzent/cebe-php-openapi": "^1.1.5",
        "guzzlehttp/psr7": "^2.0",
        "league/openapi-psr7-validator": ">=0.18, <1.0",
        "php-vcr/php-vcr": "^1.7"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "guzzlehttp/guzzle": "^7.0",
        "k-kinzal/php-ai-toolkit": "dev-main",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "OasFake\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OasFake\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test": "php -d error_reporting='E_ALL & ~E_DEPRECATED' vendor/bin/phpunit",
        "test:coverage": "XDEBUG_MODE=coverage php -d error_reporting='E_ALL & ~E_DEPRECATED' vendor/bin/phpunit --coverage-html coverage",
        "test:unit": "php -d error_reporting='E_ALL & ~E_DEPRECATED' vendor/bin/phpunit tests/Unit/",
        "lint": [
            "@format:check",
            "phpstan analyse --memory-limit=512M"
        ],
        "format": "php-cs-fixer fix --allow-risky=yes",
        "format:check": "php-cs-fixer fix --dry-run --diff --allow-risky=yes"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "name": "php-ai-toolkit",
            "type": "vcs",
            "url": "https://github.com/k-kinzal/php-ai-toolkit.git"
        }
    ]
}
